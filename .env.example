# ================================
# Yamenshat API - Generic example
# انسخ هذا الملف إلى .env.development أو .env.production حسب البيئة
# ================================

# التطبيق
APP_NAME="Yamenshat API"
APP_VERSION="2.5.0"
DEBUG=False

# قاعدة البيانات
# Development: sqlite:///./yamenshat.db
# Production : postgresql://user:password@host:5432/yamenshat
DATABASE_URL=""

# JWT / Auth
SECRET_KEY="__SET_IN_HOSTING_ENV__"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Firebase Admin SDK
FIREBASE_PROJECT_ID="__SET_IN_HOSTING_ENV__"
FIREBASE_PRIVATE_KEY_ID="__SET_IN_HOSTING_ENV__"
FIREBASE_PRIVATE_KEY="__SET_IN_HOSTING_ENV__"
FIREBASE_CLIENT_EMAIL="__SET_IN_HOSTING_ENV__"
FIREBASE_CLIENT_ID="__SET_IN_HOSTING_ENV__"
FIREBASE_AUTH_URI="https://accounts.google.com/o/oauth2/auth"
FIREBASE_TOKEN_URI="https://oauth2.googleapis.com/token"

# CORS
ALLOWED_ORIGINS='["https://web-50ne.onrender.com","https://yamen-yasry.onrender.com"]'
