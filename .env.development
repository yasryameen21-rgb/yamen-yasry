# إعدادات بيئة التطوير (Development)
APP_NAME="Yamenshat API - Dev"
APP_VERSION="1.0.0-dev"
DEBUG=True

# قاعدة البيانات (SQLite للتطوير)
DATABASE_URL="sqlite:///./yamenshat.db"

# JWT والمصادقة (مفاتيح تجريبية)
SECRET_KEY="dev-secret-key-for-testing-only"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Firebase (ضع قيمك التجريبية هنا)
FIREBASE_PROJECT_ID="dev-project-id"

# CORS
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
